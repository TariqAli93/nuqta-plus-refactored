{
  "name": "@nuqtaplus/backend",
  "version": "1.0.12",
  "description": "نقطة بلس - نظام إدارة نقاط البيع والمخازن",
  "type": "module",
  "main": "src/server.js",
  "author": "NuqtaPlus Team",
  "license": "Proprietary",
  "scripts": {
    "dev": "node --watch src/server.js --host",
    "start": "node src/server.js",
    "build": "node ../build-backend.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "node src/seed.js",
    "seed:demo": "node src/seed.js --demo",
    "seed:reset": "node src/seed.js --reset --demo",
    "migrate:from-sqlite": "node src/scripts/migrate-sqlite-to-pg.js",
    "bench:credit-job": "node src/scripts/perf-benchmark.js",
    "job:credit-scoring": "node -e \"import('./src/jobs/creditScoringJob.js').then(m => m.runCreditScoringJob()).then(r => { console.log(r); process.exit(0); }).catch(e => { console.error(e); process.exit(1); })\"",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/websocket": "^11.2.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8",
    "onnxruntime-node": "^1.20.0"
  },
  "devDependencies": {
    "cors": "^2.8.5",
    "drizzle-kit": "^0.29.1",
    "express": "^5.2.1",
    "morgan": "^1.10.1"
  }
}
